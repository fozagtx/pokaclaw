NEXT_PUBLIC_WALLET_CONNECT_ID=xxx
# SUBSTRATE_WS_ENDPOINT=wss://rpc.polkadot.io
SUBSTRATE_WS_ENDPOINT=wss://westend-rpc.polkadot.io

# AI Provider: "ollama" (local) or "openrouter" (cloud)
# If OPENROUTER_API_KEY is set and AI_PROVIDER is not, defaults to openrouter
AI_PROVIDER=openrouter

# Ollama (local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# OpenRouter (cloud)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
